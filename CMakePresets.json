{
	"version": 10,
	"cmakeMinimumRequired": {
		"major": 3,
		"minor": 21,
		"patch": 0
	},
	"configurePresets": [
		{
			"name": "Default",
			"displayName": "Default",
			"binaryDir": "build"
		},
		{
			"name": "DefaultNinja",
			"displayName": "DefaultNinja",
			"inherits": "Default",
			"generator": "Ninja"
		},
		{
			"name": "Emscripten",
			"displayName": "Emscripten",
			"binaryDir": "build-emscripten",
			"toolchainFile": "$env{EMSCRIPTEN_ROOT}/cmake/Modules/Platform/Emscripten.cmake",
			"cacheVariables": {
				"RADIANT_GENERATE_GAMEPACKS": true,
				"RADIANT_USE_ASSIMP": false,
				"RADIANT_SUPPORT_SOURCE": true,
				"RADIANT_BUILD_MBSPC": false,
				"RADIANT_BUILD_Q3MAP2": false
			}
		},
		{
			"name": "EmscriptenNinja",
			"displayName": "EmscriptenNinja",
			"inherits": "Emscripten",
			"generator": "Ninja"
		}
	],
	"buildPresets": [
		{
			"name": "Default",
			"configurePreset": "Default"
		},
		{
			"name": "DefaultNinja",
			"configurePreset": "DefaultNinja"
		},
		{
			"name": "Emscripten",
			"configurePreset": "Emscripten"
		},
		{
			"name": "EmscriptenNinja",
			"configurePreset": "EmscriptenNinja"
		}
	]
}
